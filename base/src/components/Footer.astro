---
import { Icon } from "astro-icon/components";

import { getCommitHash, getFullCommitHash } from "../lib/git";

import { execSync } from "node:child_process";

const shortHash = execSync("git rev-parse --short HEAD").toString().trim();
const fullHash = execSync("git rev-parse HEAD").toString().trim();

const commitUrl = `https://github.com/silverbeet-technology/website/commit/${fullHash}`;
---

<footer
	id="contact"
	class="w-full py-12 px-4 border-t border-gray-200 bg-white"
	role="contentinfo"
>
	<div class="max-w-6xl mx-auto">
		<div class="grid md:grid-cols-3 gap-8 mb-8">
			<div>
				<h2 class="text-lg font-semibold text-gray-900 mb-4">
					Silverbeet Technology
				</h2>

				<ul class="space-y-2">
					<li>
						<a
							href="https://www.openstreetmap.org/search?query=5830+East+2nd+Street%2C+Casper%2C+Wyoming+82609&zoom=5&minlon=-138.03222656250003&minlat=20.715015145512098&maxlon=-53.65722656250001&maxlat=52.02545860348814#map=18/42.844835/-106.235207"
							class="flex items-center gap-2 text-gray-600 hover:text-gray-900 transition-colors"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Our location on OpenStreetMap (opens in new tab)"
						>
							<Icon name="tabler:world" class="w-5 h-5" aria-hidden="true" />
							<span>
								<p class="text-gray-600">5830 East 2nd Street, Suite 7000</p>
							</span>
						</a>
					</li>
					<!--<li>
						<a
							href="https://www.whitepages.com/phone/1-307-456-7890"
							class="flex items-center gap-2 text-gray-600 hover:text-gray-900 transition-colors"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Our phone number on Whitepages (opens in new tab)"
						>
							<Icon
								name="tabler:phone"
								class="w-5 h-5"
								aria-hidden="true"
							/>
							<span>
								<p class="text-gray-600">
								(307) 456-7890 (fixme)
							  </p>
							</span>
							</a>
					</li>-->
					<li>
						<a
							href="mailto:hello @ silverbeet . tech?subject=Hello%20Silverbeet"
							class="flex items-center gap-2 text-gray-600 hover:text-gray-900 transition-colors"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Email me and say hello"
						>
							<Icon name="tabler:mail" class="w-5 h-5" aria-hidden="true" />
							<span>
								<p class="text-gray-600">hello @ silverbeet . tech</p>
							</span>
						</a>
					</li>
				</ul>
			</div>

			<div>
				<h2 class="text-lg font-semibold text-gray-900 mb-4">Pages</h2>
				<ul class="space-y-2">
					<!--<li>
						<a
							href="/services/"
							class="text-gray-600 hover:text-gray-900 transition-colors"
							>Services</a
						>
					</li>-->
					<li>
						<a
							href="/about/"
							class="text-gray-600 hover:text-gray-900 transition-colors"
							>About</a
						>
					</li>
					<li>
						<a
							href="/colophon/"
							class="text-gray-600 hover:text-gray-900 transition-colors"
							>Colophon</a
						>
					</li>
					<li>
						<a
							href="/contact/"
							class="text-gray-600 hover:text-gray-900 transition-colors"
							>Contact</a
						>
					</li>
					<li>
						<a
							href="/privacy-policy/"
							class="text-gray-600 hover:text-gray-900 transition-colors"
							>Privacy Policy</a
						>
					</li>
					<li>
						<a
							href="/terms-and-conditions/"
							class="text-gray-600 hover:text-gray-900 transition-colors"
							>Terms and Conditions</a
						>
					</li>
				</ul>
			</div>
			<div>
				<h2 class="text-lg font-semibold text-gray-900 mb-4">Connect</h2>
				<ul class="space-y-2">
					<li>
						<a
							href="https://github.com/silverbeet-technology/"
							class="flex items-center gap-2 text-gray-600 hover:text-gray-900 transition-colors"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Visit our GitHub (opens in new tab)"
						>
							<Icon
								name="tabler:brand-github"
								class="w-5 h-5"
								aria-hidden="true"
							/>
							<span>GitHub</span></a
						>
					</li>
					<li>
						<a
							href="https://www.linkedin.com/company/silverbeet-technology-llc/"
							class="flex items-center gap-2 text-gray-600 hover:text-gray-900 transition-colors"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Follow us on LinkedIn (opens in new tab)"
						>
							<Icon
								name="tabler:brand-linkedin"
								class="w-5 h-5"
								aria-hidden="true"
							/>
							<span>LinkedIn</span></a
						>
					</li>
					<li>
						<a
							href="/contact/"
							class="flex items-center gap-2 text-gray-600 hover:text-gray-900 transition-colors"
						>
							<Icon name="tabler:mail" class="w-5 h-5" aria-hidden="true" />
							<span>Email</span></a
						>
					</li>
				</ul>
			</div>
		</div>
		<div class="pt-8 border-t border-gray-200 text-center text-gray-600">
			<p>
				© {new Date().getFullYear()} All rights reserved — Built with{" "}
				<a href="https://astro.build">Astro</a> —{" "}
				<a
					href="https://github.com/silverbeet-technology/website"
					target="_blank"
					rel="noreferrer"
				>
					Source
				</a>
				—{" "}
				Commit{" "}
				<a
					href={commitUrl}
					target="_blank"
					rel="noreferrer"
					class="commit-badge"
					title="Click to view commit, or copy SHA"
					data-sha-full={fullHash}
				>
					<svg
						class="github-icon"
						viewBox="0 0 16 16"
						width="14"
						height="14"
						aria-hidden="true"
					>
						<path
							fill="currentColor"
							d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
      0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13
      -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66
      .07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95
      0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12
      0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27
      .68 0 1.36.09 2 .27
      1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12
      .51.56.82 1.27.82 2.15
      0 3.07-1.87 3.75-3.65 3.95
      .29.25.54.73.54 1.48
      0 1.07-.01 1.93-.01 2.2
      0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8
      c0-4.42-3.58-8-8-8z"
						></path>
					</svg>

					{shortHash}
				</a>
			</p>
		</div>
	</div>

	<script is:inline>
		function copyCommitSha(event) {
			const el = event.currentTarget;
			const sha = el.dataset.shaFull;
			navigator.clipboard
				.writeText(sha)
				.then(() => {
					el.classList.add("copied");

					setTimeout(() => {
						el.classList.remove("copied");
					}, 900);
				})
				.catch((err) => {
					console.error("Failed to copy SHA", err);
				});
		}

		// attach listeners after DOM loads
		window.addEventListener("DOMContentLoaded", () => {
			document.querySelectorAll(".commit-badge").forEach((el) => {
				el.addEventListener("click", (event) => {
					copyCommitSha(event);
				});
			});
		});
	</script>
</footer>
