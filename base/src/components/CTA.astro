---
import ScrollReveal from "./ScrollReveal.tsx";
import { Icon } from "astro-icon/components";
---

<section id="about" class="max-w-6xl mx-auto px-4 py-20">
	<ScrollReveal client:idle scale={true}>
		<div class="bg-black rounded-2xl p-12 text-center text-white">
			<h2 class="text-4xl font-bold mb-4">Ready to Get Started?</h2>
			<p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
				Reach out, let’s talk about what you’re working on and where you want to
				go next — and how I can help you get there.
			</p>
			<a
				href="/contact/"
				class="inline-flex items-center gap-2 px-8 py-3 bg-white text-black rounded-lg hover:bg-gray-100 transition-colors font-medium"
			>
				Contact
			</a>
		</div>
	</ScrollReveal>
</section>
